import React, { useState } from 'react';
import { Card, Typography, Button, Divider, Row, Col, Image } from 'antd';
import momo from "src/assets/images/momo.png";
import vnpay from "src/assets/images/vnpay.png";
import zalopay from "src/assets/images/zalopay.png";
import payoo from "src/assets/images/payoo.png";
import '../../styles/ElectronicPayment.scss';

const { Title, Text, Paragraph } = Typography;

const ElectronicPayment = () => {
  const paymentOptions = [
    { name: 'MoMo', logo: momo },
    { name: 'VNPay', logo: vnpay },
    { name: 'ZaloPay', logo: zalopay },
    { name: 'Payoo', logo: payoo }
  ];

  const [selectedPayment, setSelectedPayment] = useState(null);

  return (
    <Card className="electronic-payment">
      <Title level={5}>Cổng thanh toán điện tử</Title>
      <Paragraph>
        Thanh toán hội phí nhanh chóng qua các cổng thanh toán điện tử uy tín:
      </Paragraph>

      <Row gutter={[16, 16]} className="payment-options">
        {paymentOptions.map((option, index) => (
          <Col xs={12} sm={6} key={index}>
            <Card 
              hoverable
              className={`payment-option-card ${selectedPayment === index ? 'selected' : ''}`}
              onClick={() => setSelectedPayment(index)}
            >
              <div className="payment-logo">
                <Image 
                  src={option.logo} 
                  alt={option.name} 
                  preview={false}
                  width={80}
                />
              </div>
              <Text className="payment-name">{option.name}</Text>
            </Card>
          </Col>
        ))}
      </Row>

      {selectedPayment !== null && (
        <div className="selected-payment-details">
          <Divider className="payment-divider" />
          <Title level={5}>Thanh toán qua {paymentOptions[selectedPayment].name}</Title>
          <Button type="primary" className="proceed-payment">
            Tiến hành thanh toán
          </Button>
        </div>
      )}
    </Card>
  );
};

export default ElectronicPayment;
