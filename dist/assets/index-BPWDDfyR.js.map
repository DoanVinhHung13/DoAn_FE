import { useEffect, useState } from 'react';
import '../../styles/QRCodePayment.scss';
import FeeManagement from 'src/services/FeeManagement';

const QRCodePayment = ({ amount }) => {
  const [copied, setCopied] = useState(false);
  const [activeTab, setActiveTab] = useState('guide');
  const [qrImageUrl, setQrImageUrl] = useState('');

  // Lấy ảnh QR từ API
  useEffect(() => {

    const fetchQR = async () => {
      try {
        const res = await FeeManagement.getBankQR();
        const url = res?.Object?.FileUrl;
        if (url) setQrImageUrl(url);
        console.log(qrImageUrl)
      } catch (err) {
        console.error('Lỗi khi lấy ảnh QR:', err);
      }
    };

    fetchQR();
  }, []);

  const formattedAmount = Number(amount).toLocaleString("vi-VN") + ' VND';

  const bankInfo = {
    accountNumber: '0123456789',
    accountName: 'HIEP HOI TU VAN NANG CAO SUC KHOE',
    bankName: 'MBBank',
    amount: formattedAmount,
    content: 'THANHTOAN HOIPHI'
  };

  const copyToClipboard = (text) => {
    navigator.clipboard.writeText(text);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  return (
    <div className="qr-payment">
      <div className="header">
        <h2>Thanh Toán Qua Mã QR</h2>
        <p>An toàn - Nhanh chóng - Tiện lợi</p>
      </div>

      <div className="qr-section">
        <div className="qr-wrapper">
          <div className="qr-box">
            <img
              // src={qrImageUrl || 'https://img.vietqr.io/image/MB-0347365411-compact.png'}
              src={'https://img.vietqr.io/image/MB-0347365411-compact.png'}
              alt="QR Code thanh toán"
            />
          </div>
        </div>

        <div className="qr-caption">Quét mã QR để thanh toán nhanh chóng</div>

        <div className="bank-info">
          <div className="row">
            <span>Ngân hàng:</span>
            <span className="value">{bankInfo.bankName}</span>
          </div>
          <div className="row">
            <span>Số tài khoản:</span>
            <div className="flex">
              <span className="value">{bankInfo.accountNumber}</span>
              <button onClick={() => copyToClipboard(bankInfo.accountNumber)}>
                {copied ? '✓' : '📋'}
              </button>
            </div>
          </div>
          <div className="row">
            <span>Tên tài khoản:</span>
            <span className="value">{bankInfo.accountName}</span>
          </div>
          <div className="row">
            <span>Số tiền:</span>
            <span className="value amount">{bankInfo.amount}</span>
          </div>
          <div className="row">
            <span>Nội dung CK:</span>
            <div className="flex">
              <span className="value">{bankInfo.content}</span>
              <button onClick={() => copyToClipboard(bankInfo.content)}>
                {copied ? '✓' : '📋'}
              </button>
            </div>
          </div>
        </div>
      </div>

      <div className="tabs">
        <button
          className={activeTab === 'guide' ? 'active' : ''}
          onClick={() => setActiveTab('guide')}
        >
          <div className="icon-label">📱 Hướng dẫn</div>
        </button>
        <button
          className={activeTab === 'notice' ? 'active' : ''}
          onClick={() => setActiveTab('notice')}
        >
          <div className="icon-label">⚠️ Lưu ý</div>
        </button>
      </div>

      <div className="tab-content">
        {activeTab === 'guide' && (
          <div>
            <h3>💳 Hướng dẫn thanh toán</h3>
            <ol>
              <li>Mở ứng dụng ngân hàng hoặc ví điện tử</li>
              <li>Chọn chức năng quét mã QR hoặc chuyển tiền</li>
              <li>Quét mã QR hoặc nhập thông tin chuyển khoản</li>
              <li>Kiểm tra thông tin giao dịch trước khi xác nhận</li>
              <li>Hoàn tất giao dịch và lưu biên lai thanh toán</li>
            </ol>
          </div>
        )}

        {activeTab === 'notice' && (
          <div>
            <h3>⚠️ Lưu ý quan trọng</h3>
            <ul>
              <li><span className="dot" />Không thay đổi nội dung chuyển khoản để hệ thống xác nhận thanh toán chính xác</li>
              <li><span className="dot" />Sau khi thanh toán thành công, hệ thống sẽ cập nhật trạng thái trong vòng 24 giờ</li>
              <li><span className="dot" />Nếu cần hỗ trợ, vui lòng liên hệ hotline: 1900 xxxx hoặc email: support@example.com</li>
            </ul>
          </div>
        )}
      </div>

      <div className="footer">
        Thông tin thanh toán được bảo mật và tuân thủ quy định của Ngân hàng Nhà nước Việt Nam
      </div>
    </div>
  );
};

export default QRCodePayment;
